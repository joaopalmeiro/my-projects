# https://docs.npmjs.com/cli/v11/using-npm/config#config-settings
# https://docs.npmjs.com/cli/v11/using-npm/config#environment-variables
# https://docs.npmjs.com/cli/v11/using-npm/config#default-configs

allow-git="none"
audit=false
engine-strict=true
fund=false
git-tag-version=false
ignore-scripts=true
min-release-age=7
package-lock=true
progress=true
save-exact=true
update-notifier=false
